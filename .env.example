# ============================================================
#  Adam Biotech — Environment Template
#  Copy this file to .env and fill in your real values.
#  This file IS safe to commit. .env is NOT.
# ============================================================

# Supabase — app.supabase.com → your project → Settings → API
# Use the SERVICE ROLE key (not anon key) — server-side only
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# SendGrid — app.sendgrid.com → Settings → API Keys → Create API Key
# (these go in Supabase Edge Function env vars, not here — see README)
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY

# Email addresses
TEAM_EMAIL=team@adambiotech.com
FROM_EMAIL=hello@adambiotech.com
FROM_NAME=Adam Biotech

# Server port (optional, defaults to 3000)
PORT=3000
